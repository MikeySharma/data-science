import pandas as pd
from sklearn import linear_model
from sklearn.preprocessing import StandardScaler
from sklearn.linear_model import LinearRegression
scale = StandardScaler()
df = pd.read_csv('cars2.csv')
x = df[['Weight', 'Volume']]
y = df[['CO2']]
scaledX = scale.fit_transform(x)

model = LinearRegression()
model.fit(x, y)

modelTrainedWithoutScaling = LinearRegression()
modelTrainedWithoutScaling.fit(scaledX, y)

yPredict = model.predict([[2300, 1.3]])
y2Predict = modelTrainedWithoutScaling.predict([[2300, 1.3]])
print(yPredict, y2Predict)

